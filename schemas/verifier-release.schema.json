{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/verifier-release.schema.json",
  "title": "OpenCompliance Verifier Release Manifest",
  "type": "object",
  "required": [
    "$schema",
    "releaseId",
    "verifierVersion",
    "generatedAt",
    "bundleLayoutVersion",
    "entrypoints",
    "includedFixtures",
    "includedRoots",
    "verifierContractPath",
    "signedArtifactManifestPath"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://opencompliancefoundation.com/specs/schemas/verifier-release.schema.json"
    },
    "releaseId": {
      "type": "string",
      "minLength": 1
    },
    "verifierVersion": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "bundleLayoutVersion": {
      "type": "integer",
      "minimum": 1
    },
    "entrypoints": {
      "type": "object",
      "required": [
        "verifyFixture",
        "runLeanBatch",
        "validateExamples",
        "verifySignedArtifacts",
        "verifyTransparency"
      ],
      "properties": {
        "verifyFixture": {
          "type": "string",
          "minLength": 1
        },
        "runLeanBatch": {
          "type": "string",
          "minLength": 1
        },
        "validateExamples": {
          "type": "string",
          "minLength": 1
        },
        "verifySignedArtifacts": {
          "type": "string",
          "minLength": 1
        },
        "verifyTransparency": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "includedFixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "includedRoots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verifierContractPath": {
      "type": "string",
      "minLength": 1
    },
    "publicKeyPath": {
      "type": "string",
      "minLength": 1
    },
    "signedArtifactManifestPath": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
