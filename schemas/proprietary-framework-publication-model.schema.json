{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/proprietary-framework-publication-model.schema.json",
  "title": "OpenCompliance Proprietary Framework Publication Model",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "purpose",
    "publicationTiers",
    "frameworkPolicies",
    "workflow"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "publicationTiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "tierId",
          "title",
          "allowedArtifacts"
        ],
        "properties": {
          "tierId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "allowedArtifacts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "frameworkPolicies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "framework",
          "sourceAvailability",
          "publicAllowed",
          "privateAllowed",
          "publicBlocked"
        ],
        "properties": {
          "framework": {
            "type": "string",
            "minLength": 1
          },
          "sourceAvailability": {
            "type": "string",
            "minLength": 1
          },
          "publicAllowed": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "privateAllowed": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "publicBlocked": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "workflow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step",
          "name",
          "output"
        ],
        "properties": {
          "step": {
            "type": "integer",
            "minimum": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "output": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
