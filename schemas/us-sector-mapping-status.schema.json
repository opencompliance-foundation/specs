{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/us-sector-mapping-status.schema.json",
  "title": "OpenCompliance U.S. Sector Mapping Status",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "purpose",
    "programs"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "programs": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "programId",
          "title",
          "summary",
          "workstreams",
          "publicNotes"
        ],
        "properties": {
          "programId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "object"
          },
          "frameworks": {
            "type": "array"
          },
          "workstreams": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "id",
                "title",
                "status",
                "summary",
                "remainingWork",
                "blockedBy"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "minLength": 1
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
                },
                "remainingWork": {
                  "type": "string",
                  "minLength": 1
                },
                "blockedBy": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "publicNotes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
