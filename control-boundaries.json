          "OpenCompliance.Examples.exClaim001_proved",
          "OpenCompliance.Examples.exClaim101_proved"
        ]
      },
      "publicExamples": [
        "minimal",
        "medium"
      ],
      "sourceMappings": [
        {
          "framework": "SOC 2",
          "family": "access_control",
          "controlId": "soc2.family.access_control"
        },
        {
          "framework": "ISO 27001",
          "family": "identity_and_access_management",
          "controlId": "iso27001.family.identity_and_access_management"
        },
        {
          "framework": "IRAP",
