{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/signed-artifact-manifest.schema.json",
  "title": "OpenCompliance Signed Artifact Manifest",
  "type": "object",
  "required": [
    "signatureBundleId",
    "generatedAt",
    "signer",
    "artifacts"
  ],
  "properties": {
    "signatureBundleId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "signer": {
      "type": "object",
      "required": [
        "signerId",
        "keyId",
        "algorithm",
        "publicKeyPath"
      ],
      "properties": {
        "signerId": {
          "type": "string",
          "minLength": 1
        },
        "keyId": {
          "type": "string",
          "minLength": 1
        },
        "algorithm": {
          "type": "string",
          "enum": [
            "Ed25519"
          ]
        },
        "publicKeyPath": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "signature"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          },
          "signature": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "note": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
