{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/composed-certificate.schema.json",
  "title": "OpenCompliance Composed Certificate",
  "type": "object",
  "required": [
    "composedCertificateId",
    "status",
    "generatedAt",
    "organisation",
    "frameworkIntent",
    "scope",
    "componentCertificates",
    "controlRefs",
    "coverage",
    "compositionRule"
  ],
  "properties": {
    "composedCertificateId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "issued"
      ]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "organisation": {
      "type": "string",
      "minLength": 1
    },
    "frameworkIntent": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "type": "object"
    },
    "componentCertificates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "componentName",
          "certificateId",
          "bundleId",
          "profileId",
          "controlRefs",
          "proofBundleSha256"
        ],
        "properties": {
          "componentName": {
            "type": "string",
            "minLength": 1
          },
          "certificateId": {
            "type": "string",
            "minLength": 1
          },
          "bundleId": {
            "type": "string",
            "minLength": 1
          },
          "profileId": {
            "type": "string",
            "minLength": 1
          },
          "controlRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "proofBundleSha256": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          }
        },
        "additionalProperties": false
      }
    },
    "controlRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "coverage": {
      "type": "object",
      "required": [
        "proved",
        "attested",
        "judgmentRequired",
        "evidenceMissing"
      ],
      "properties": {
        "proved": {
          "type": "integer",
          "minimum": 0
        },
        "attested": {
          "type": "integer",
          "minimum": 0
        },
        "judgmentRequired": {
          "type": "integer",
          "minimum": 0
        },
        "evidenceMissing": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "compositionRule": {
      "type": "string",
      "minLength": 1
    },
    "note": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
