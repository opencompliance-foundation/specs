{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/revocation.schema.json",
  "title": "OpenCompliance Revocation",
  "type": "object",
  "required": [
    "revocationId",
    "artifactType",
    "artifactId",
    "revokedAt",
    "reason"
  ],
  "properties": {
    "revocationId": {
      "type": "string",
      "minLength": 1
    },
    "artifactType": {
      "type": "string",
      "minLength": 1
    },
    "artifactId": {
      "type": "string",
      "minLength": 1
    },
    "revokedAt": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "supersededBy": {
      "type": "string"
    },
    "note": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
