        },
        {
          "framework": "GDPR",
          "family": "security_of_processing",
          "controlId": "gdpr.family.security_of_processing"
        }
      ],
      "boundary": {
        "proves": "Scoped administrative identities require MFA and conditional access in the declared environment.",
        "doesNotProve": [
          "Whole-program access governance adequacy",
          "Periodic access review completion unless a typed export exists"
        ]
      }
    },
