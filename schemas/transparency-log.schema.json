{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/transparency-log.schema.json",
  "title": "OpenCompliance Transparency Log",
  "type": "object",
  "required": [
    "logId",
    "generatedAt",
    "bundleId",
    "hashAlgorithm",
    "rootHash",
    "entries"
  ],
  "properties": {
    "logId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "hashAlgorithm": {
      "type": "string",
      "enum": [
        "sha256"
      ]
    },
    "rootHash": {
      "type": "string",
      "minLength": 64,
      "maxLength": 64
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "index",
          "artifactType",
          "path",
          "artifactSha256",
          "leafHash"
        ],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 0
          },
          "artifactType": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "artifactSha256": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          },
          "leafHash": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
