{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliance.aguilar-pelaez.co.uk/specs/schemas/proof-bundle.schema.json",
  "title": "OpenCompliance Proof Bundle",
  "type": "object",
  "required": [
    "bundleId",
    "generatedAt",
    "verifierVersion",
    "organisation",
    "profileId",
    "frameworkIntent",
    "scope",
    "claims",
    "summary",
    "nextActions",
    "proofRunner"
  ],
  "properties": {
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "verifierVersion": {
      "type": "string",
      "minLength": 1
    },
    "organisation": {
      "type": "string",
      "minLength": 1
    },
    "profileId": {
      "type": "string",
      "minLength": 1
    },
    "frameworkIntent": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "type": "object"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claimId",
          "title",
          "result",
          "frameworkMappings",
          "controlRefs",
          "evidenceRefs",
          "basis"
        ],
        "properties": {
          "claimId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "proved",
              "attested",
              "failed",
              "stale_evidence",
              "judgment_required",
              "evidence_missing"
            ]
          },
          "frameworkMappings": {
            "type": "array"
          },
          "controlRefs": {
            "type": "array"
          },
          "evidenceRefs": {
            "type": "array"
          },
          "basis": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "proved",
        "attested",
        "failed",
        "staleEvidence",
        "judgmentRequired",
        "evidenceMissing"
      ],
      "properties": {
        "proved": {
          "type": "integer",
          "minimum": 0
        },
        "attested": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "staleEvidence": {
          "type": "integer",
          "minimum": 0
        },
        "judgmentRequired": {
          "type": "integer",
          "minimum": 0
        },
        "evidenceMissing": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proofRunner": {
      "type": "object",
      "required": [
        "batchId",
        "fixture",
        "status",
        "theoremCount",
        "verifiedTheorems",
        "command"
      ],
      "properties": {
        "batchId": {
          "type": "string",
          "minLength": 1
        },
        "fixture": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "verified"
          ]
        },
        "theoremCount": {
          "type": "integer",
          "minimum": 0
        },
        "verifiedTheorems": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
