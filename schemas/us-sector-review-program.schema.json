{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/us-sector-review-program.schema.json",
  "title": "OpenCompliance U.S. Sector Review Program",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "purpose",
    "targetPrograms",
    "reviewTracks",
    "reviewerRoles",
    "phases",
    "currentState"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "targetPrograms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reviewTracks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "trackId",
          "goal",
          "requiredRoles"
        ],
        "properties": {
          "trackId": {
            "type": "string",
            "minLength": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "requiredRoles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "reviewerRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "roleId",
          "description"
        ],
        "properties": {
          "roleId": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "phaseId",
          "goal",
          "passCriteria"
        ],
        "properties": {
          "phaseId": {
            "type": "string",
            "minLength": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "passCriteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "currentState": {
      "type": "object",
      "required": [
        "status",
        "remainingBlockers"
      ],
      "properties": {
        "status": {
          "type": "string",
          "minLength": 1
        },
        "remainingBlockers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
