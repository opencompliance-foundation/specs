{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/proof-bundle.schema.json",
  "title": "OpenCompliance Proof Bundle",
  "type": "object",
  "required": [
    "bundleId",
    "generatedAt",
    "verifierVersion",
    "organisation",
    "profileId",
    "frameworkIntent",
    "scope",
    "claims",
    "summary",
    "nextActions",
    "proofRunner"
  ],
  "properties": {
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "verifierVersion": {
      "type": "string",
      "minLength": 1
    },
    "organisation": {
      "type": "string",
      "minLength": 1
    },
    "profileId": {
      "type": "string",
      "minLength": 1
    },
    "frameworkIntent": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "type": "object"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claimId",
          "title",
          "result",
          "frameworkMappings",
          "controlRefs",
          "evidenceRefs",
          "basis"
        ],
        "properties": {
          "claimId": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "proved",
              "attested",
              "failed",
              "stale_evidence",
              "judgment_required",
              "evidence_missing"
            ]
          },
          "frameworkMappings": {
            "type": "array"
          },
          "controlRefs": {
            "type": "array"
          },
          "evidenceRefs": {
            "type": "array"
          },
          "basis": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "proved",
        "attested",
        "failed",
        "staleEvidence",
        "judgmentRequired",
        "evidenceMissing"
      ],
      "properties": {
        "proved": {
          "type": "integer",
          "minimum": 0
        },
        "attested": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "staleEvidence": {
          "type": "integer",
          "minimum": 0
        },
        "judgmentRequired": {
          "type": "integer",
          "minimum": 0
        },
        "evidenceMissing": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proofRunner": {
      "type": "object",
      "required": [
        "batchId",
        "fixture",
        "status",
        "theoremCount",
        "verifiedTheorems",
        "importedModules",
        "verifiedClaims",
        "typedBoundaryLayer",
        "boundaryInventory",
        "command"
      ],
      "properties": {
        "batchId": {
          "type": "string",
          "minLength": 1
        },
        "fixture": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "verified"
          ]
        },
        "theoremCount": {
          "type": "integer",
          "minimum": 0
        },
        "verifiedTheorems": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "importedModules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verifiedClaims": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "claimId",
              "controlId",
              "module",
              "predicate",
              "evidenceClaimType",
              "theorem"
            ],
            "properties": {
              "claimId": {
                "type": "string",
                "minLength": 1
              },
              "controlId": {
                "type": "string",
                "minLength": 1
              },
              "module": {
                "type": "string",
                "minLength": 1
              },
              "predicate": {
                "type": "string",
                "minLength": 1
              },
              "evidenceClaimType": {
                "type": "string",
                "minLength": 1
              },
              "theorem": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "typedBoundaryLayer": {
          "type": "object",
          "required": [
            "source",
            "dependency",
            "typedModules",
            "runtimeConsumedClaims",
            "runtimeStatus"
          ],
          "properties": {
            "source": {
              "type": "string",
              "const": "LegalLean"
            },
            "dependency": {
              "type": "object",
              "required": [
                "package",
                "primaryImports"
              ],
              "properties": {
                "package": {
                  "type": "string",
                  "minLength": 1
                },
                "primaryImports": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "typedModules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "module",
                  "covers"
                ],
                "properties": {
                  "module": {
                    "type": "string",
                    "minLength": 1
                  },
                  "covers": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "additionalProperties": false
              }
            },
            "runtimeConsumedClaims": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "runtimeStatus": {
              "type": "object",
              "required": [
                "typedControlResultsLive",
                "riskAcceptanceDefeasibilityLive",
                "discretionaryTermTypingLive",
                "fullMinimalSolverAgreement",
                "pythonVerdictLayerReplaced"
              ],
              "properties": {
                "typedControlResultsLive": {
                  "type": "boolean"
                },
                "riskAcceptanceDefeasibilityLive": {
                  "type": "boolean"
                },
                "discretionaryTermTypingLive": {
                  "type": "boolean"
                },
                "fullMinimalSolverAgreement": {
                  "type": "boolean"
                },
                "pythonVerdictLayerReplaced": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "boundaryInventory": {
          "type": "object",
          "required": [
            "provedClaimCount",
            "leanBackedClaimCount",
            "omittedProvedClaims"
          ],
          "properties": {
            "provedClaimCount": {
              "type": "integer",
              "minimum": 0
            },
            "leanBackedClaimCount": {
              "type": "integer",
              "minimum": 0
            },
            "omittedProvedClaims": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "claimId",
                  "title",
                  "controlRefs",
                  "reason"
                ],
                "properties": {
                  "claimId": {
                    "type": "string",
                    "minLength": 1
                  },
                  "title": {
                    "type": "string",
                    "minLength": 1
                  },
                  "controlRefs": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "reason": {
                    "type": "string",
                    "enum": [
                      "no_evidence_ref",
                      "no_public_lean_predicate",
                      "no_registered_batch_builder"
                    ]
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
