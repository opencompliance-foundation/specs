{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliance.aguilar-pelaez.co.uk/specs/schemas/witness-receipt.schema.json",
  "title": "OpenCompliance Witness Receipt",
  "type": "object",
  "required": [
    "receiptId",
    "issuedAt",
    "bundleId",
    "verifierVersion",
    "replayBundleId",
    "replayResult",
    "checkedArtifacts"
  ],
  "properties": {
    "receiptId": {
      "type": "string",
      "minLength": 1
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "verifierVersion": {
      "type": "string",
      "minLength": 1
    },
    "replayBundleId": {
      "type": "string",
      "minLength": 1
    },
    "replayResult": {
      "type": "string",
      "enum": [
        "exact_match",
        "digest_mismatch"
      ]
    },
    "checkedArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifactType",
          "path",
          "sha256"
        ],
        "properties": {
          "artifactType": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          }
        },
        "additionalProperties": false
      }
    },
    "note": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
