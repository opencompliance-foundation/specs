{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/specs/schemas/witness-receipt.schema.json",
  "title": "OpenCompliance Witness Receipt",
  "type": "object",
  "required": [
    "receiptId",
    "issuedAt",
    "bundleId",
    "verifierVersion",
    "replayBundleId",
    "replayResult",
    "witness",
    "checkedArtifacts"
  ],
  "properties": {
    "receiptId": {
      "type": "string",
      "minLength": 1
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "verifierVersion": {
      "type": "string",
      "minLength": 1
    },
    "replayBundleId": {
      "type": "string",
      "minLength": 1
    },
    "replayResult": {
      "type": "string",
      "enum": [
        "exact_match",
        "digest_mismatch"
      ]
    },
    "witness": {
      "type": "object",
      "required": [
        "witnessId",
        "witnessType",
        "witnessRole",
        "trustPolicyId"
      ],
      "properties": {
        "witnessId": {
          "type": "string",
          "minLength": 1
        },
        "witnessType": {
          "type": "string",
          "enum": [
            "independent_witness"
          ]
        },
        "witnessRole": {
          "type": "string",
          "minLength": 1
        },
        "trustPolicyId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "checkedArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifactType",
          "path",
          "sha256"
        ],
        "properties": {
          "artifactType": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          }
        },
        "additionalProperties": false
      }
    },
    "note": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
